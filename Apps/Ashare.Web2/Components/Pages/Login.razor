@page "/login"
@rendermode InteractiveServer
@inject AshareApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>دخول - عشير</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title text-center">دخول بالهاتف</h2>

                @if (step == 1)
                {
                    <div class="mb-3">
                        <label class="form-label">رقم الهاتف</label>
                        <input class="form-control" placeholder="+966500000000" @bind="phoneNumber" />
                    </div>
                    <button class="btn btn-primary w-100" @onclick="RequestOtp" disabled="@loading">
                        @(loading ? "جاري الإرسال..." : "إرسال رمز التحقق")
                    </button>
                }
                else if (step == 2)
                {
                    <div class="alert alert-info">
                        <strong>وضع تجريبي:</strong> الكود أُرسل للـ logs. راجع طرفية Ashare.Api2 أو استخدم أي كود مطابق.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">رمز التحقق (6 أرقام)</label>
                        <input class="form-control" placeholder="123456" @bind="code" />
                    </div>
                    <button class="btn btn-success w-100" @onclick="VerifyOtp" disabled="@loading">
                        @(loading ? "جاري التحقق..." : "تحقق ودخول")
                    </button>
                    <button class="btn btn-link w-100 mt-2" @onclick="() => step = 1">رجوع</button>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger mt-3">@error</div>
                }
            </div>
        </div>

        <div class="mt-4 text-center text-muted">
            <small>
                حسابات تجريبية:<br />
                المالك أحمد: <code>+966500000001</code> | العميلة سارة: <code>+966500000002</code>
            </small>
        </div>
    </div>
</div>

@code {
    private int step = 1;
    private string phoneNumber = "+966500000001";
    private string code = "";
    private string challengeId = "";
    private Guid userId;
    private bool loading;
    private string error = "";

    private async Task RequestOtp()
    {
        error = "";
        loading = true;
        try
        {
            var resp = await Api.PostAsync<OtpRequestResult>("/api/auth/sms/request", new { phoneNumber });
            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Error?.Message ?? "فشل طلب الرمز";
                return;
            }
            challengeId = resp.Data.ChallengeId;
            userId = resp.Data.UserId;
            step = 2;
        }
        finally { loading = false; }
    }

    private async Task VerifyOtp()
    {
        error = "";
        loading = true;
        try
        {
            var resp = await Api.PostAsync<VerifyResult>("/api/auth/sms/verify", new
            {
                userId,
                challengeId,
                code
            });

            if (resp.Operation.Status != "Success" || resp.Data == null)
            {
                error = resp.Error?.Message ?? "كود غير صحيح";
                return;
            }

            Auth.SignIn(
                resp.Data.UserId,
                resp.Data.PhoneNumber,
                resp.Data.AccessToken,
                resp.Data.RefreshToken,
                resp.Data.ExpiresAt);

            Nav.NavigateTo("/");
        }
        finally { loading = false; }
    }

    public class OtpRequestResult
    {
        public string ChallengeId { get; set; } = "";
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
    }

    public class VerifyResult
    {
        public Guid UserId { get; set; }
        public string PhoneNumber { get; set; } = "";
        public string AccessToken { get; set; } = "";
        public string RefreshToken { get; set; } = "";
        public DateTimeOffset ExpiresAt { get; set; }
    }
}
