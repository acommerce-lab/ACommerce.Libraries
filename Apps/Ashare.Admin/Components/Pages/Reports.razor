@page "/reports"
@inject AdminApiService ApiService

<div class="reports-page">
    @if (_loading)
    {
        <div class="loading"><SfSpinner Visible="true" /></div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon primary">💵</div>
                <div class="stat-content">
                    <h3>إجمالي الإيرادات</h3>
                    <div class="value">@_stats.TotalRevenue.ToString("N0") ر.س</div>
                    <div class="change positive">@_stats.ActiveVendors معلن نشط</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon success">📅</div>
                <div class="stat-content">
                    <h3>إجمالي الحجوزات</h3>
                    <div class="value">@_stats.TotalOrders.ToString("N0")</div>
                    <div class="change positive">+@_stats.OrdersThisMonth هذا الشهر</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon warning">👥</div>
                <div class="stat-content">
                    <h3>مستخدمون جدد</h3>
                    <div class="value">@_stats.NewUsersThisMonth</div>
                    <div class="change positive">من إجمالي @_stats.TotalUsers.ToString("N0")</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon danger">🏠</div>
                <div class="stat-content">
                    <h3>العروض</h3>
                    <div class="value">@_stats.TotalListings.ToString("N0")</div>
                    <div class="change warning">@_stats.PendingListings بانتظار المراجعة</div>
                </div>
            </div>
        </div>

        <div class="card" style="margin-top: 24px;">
            <div class="card-header">
                <h2>📊 الإيرادات حسب الشهر</h2>
            </div>
            <div class="card-body">
                @if (_salesData.Count == 0)
                {
                    <p class="muted">لا توجد بيانات إيرادات بعد.</p>
                }
                else
                {
                    <SfChart Height="350px">
                        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" />
                        <ChartPrimaryYAxis LabelFormat="{value} ر.س" />
                        <ChartSeriesCollection>
                            <ChartSeries DataSource="@_salesData" XName="Label" YName="Value"
                                         Type="ChartSeriesType.SplineArea" Fill="#345454" Opacity="0.5">
                                <ChartMarker Visible="true" Height="10" Width="10" />
                            </ChartSeries>
                        </ChartSeriesCollection>
                        <ChartTooltipSettings Enable="true" />
                    </SfChart>
                }
            </div>
        </div>
    }
</div>

<style>
    .loading { display: flex; justify-content: center; padding: 60px; }
    .muted { color: #94a3b8; text-align: center; padding: 40px; }
</style>

@code {
    private bool _loading = true;
    private DashboardStats _stats = new();
    private List<ChartDataPoint> _salesData = new();

    protected override async Task OnInitializedAsync()
    {
        _stats = await ApiService.GetDashboardStatsAsync();
        _salesData = await ApiService.GetSalesChartDataAsync();
        _loading = false;
    }
}
