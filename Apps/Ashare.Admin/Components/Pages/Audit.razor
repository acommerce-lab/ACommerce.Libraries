@page "/audit"
@inject AdminSupportService Support

<div class="audit-page">
    <div class="page-header">
        <div class="search-filters">
            <SfTextBox Placeholder="نوع الكيان (ProductListing...)" @bind-Value="_entityType" Width="220px" />
            <SfTextBox Placeholder="الإجراء (Approve, Reject...)" @bind-Value="_action" Width="200px" />
            <SfButton CssClass="e-primary" OnClick="Load">بحث</SfButton>
        </div>
    </div>

    <div class="card">
        @if (_loading)
        {
            <div class="loading"><SfSpinner Visible="true" /></div>
        }
        else
        {
            <SfGrid DataSource="@_logs" AllowPaging="true" AllowSorting="true">
                <GridPageSettings PageSize="20" />
                <GridColumns>
                    <GridColumn Field="@nameof(AuditLogVm.CreatedAt)" HeaderText="الوقت" Width="160" Format="g" />
                    <GridColumn Field="@nameof(AuditLogVm.UserName)" HeaderText="المشرف" Width="140" />
                    <GridColumn HeaderText="الإجراء" Width="120">
                        <Template>
                            @{ var l = context as AuditLogVm; }
                            <span class="status-badge @LevelClass(l?.Level)">@l?.Action</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AuditLogVm.EntityType)" HeaderText="الكيان" Width="150" />
                    <GridColumn Field="@nameof(AuditLogVm.Details)" HeaderText="التفاصيل" Width="360" />
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

<style>
    .loading { display: flex; justify-content: center; padding: 40px; }
    .status-badge.info { background: #e0f2fe; color: #075985; }
    .status-badge.warning { background: #fef9c3; color: #854d0e; }
    .status-badge.danger { background: #fee2e2; color: #991b1b; }
</style>

@code {
    private List<AuditLogVm> _logs = new();
    private string _entityType = "";
    private string _action = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        var result = await Support.GetAuditLogsAsync(
            string.IsNullOrWhiteSpace(_action) ? null : _action,
            string.IsNullOrWhiteSpace(_entityType) ? null : _entityType);
        _logs = result.Items;
        _loading = false;
    }

    private string LevelClass(int? level) => level switch
    {
        1 => "warning",   // Warning
        2 or 3 => "danger", // Error, Critical
        _ => "info"
    };
}
