@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject Ashare.Admin.Services.AuthService AuthService

<div class="ac-admin-layout @(SidebarCollapsed ? "sidebar-collapsed" : "")">
    <aside class="admin-sidebar">
        <AcSidebar Title="عشير" 
                   MenuItems="@MenuItems" 
                   @bind-IsCollapsed="@SidebarCollapsed">
            <FooterContent>
                <div class="user-info">
                    <span class="user-avatar">م</span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="user-name">مدير النظام</span>
                        <button class="logout-btn" @onclick="Logout">خروج</button>
                    }
                </div>
            </FooterContent>
        </AcSidebar>
    </aside>
    
    <div class="admin-main">
        <header class="admin-header">
            <div class="header-left">
                <h1 class="page-title">@GetPageTitle()</h1>
            </div>
            <div class="header-right">
                <SfButton CssClass="e-outline" IconCss="e-icons e-bell">
                    الإشعارات
                </SfButton>
            </div>
        </header>
        
        <main class="admin-content">
            @Body
        </main>
        
        <footer class="admin-footer">
            <span>© 2025 عشير - جميع الحقوق محفوظة</span>
        </footer>
    </div>
</div>

@code {
    private bool SidebarCollapsed { get; set; } = false;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }

    private List<AcSidebar.SidebarMenuItem> MenuItems => new()
    {
        new() { Title = "لوحة التحكم", Url = "/", Icon = "📊", IsActive = IsCurrentPage("/") },
        new() { Title = "المستخدمين", Url = "/users", Icon = "👥", IsActive = IsCurrentPage("/users") },
        new() { Title = "العروض", Url = "/listings", Icon = "🏠", IsActive = IsCurrentPage("/listings") },
        new() { Title = "الحجوزات", Url = "/bookings", Icon = "📅", IsActive = IsCurrentPage("/bookings") },
        new() { Title = "الباقات", Url = "/subscriptions", Icon = "💎", IsActive = IsCurrentPage("/subscriptions") },
        new() { Title = "الدعم والشكاوى", Url = "/complaints", Icon = "🎧", IsActive = IsCurrentPage("/complaints") },
        new() { Title = "الإشعارات", Url = "/notifications", Icon = "🔔", IsActive = IsCurrentPage("/notifications") },
        new() { Title = "التقارير", Url = "/reports", Icon = "📈", IsActive = IsCurrentPage("/reports") },
        new() { Title = "التسويق", Url = "/marketing", Icon = "📣", IsActive = IsCurrentPage("/marketing") },
        new() { Title = "التحكم والإعدادات", Url = "/appconfig", Icon = "🎛️", IsActive = IsCurrentPage("/appconfig") },
        new() { Title = "الصفحات القانونية", Url = "/legal", Icon = "📄", IsActive = IsCurrentPage("/legal") },
        new() { Title = "سجل التدقيق", Url = "/audit", Icon = "🗂️", IsActive = IsCurrentPage("/audit") },
        new() { Title = "الإصدارات", Url = "/versions", Icon = "🔄", IsActive = IsCurrentPage("/versions") },
        new() { Title = "المشرفين", Url = "/admin-users", Icon = "🛡️", IsActive = IsCurrentPage("/admin-users") },
        new() { Title = "الأدوار", Url = "/roles", Icon = "🔐", IsActive = IsCurrentPage("/roles") },
    };

    private bool IsCurrentPage(string url)
    {
        var currentPath = new Uri(NavigationManager.Uri).AbsolutePath;
        return currentPath == url || (url != "/" && currentPath.StartsWith(url));
    }

    private string GetPageTitle()
    {
        var currentPath = new Uri(NavigationManager.Uri).AbsolutePath;

        // Handle user details page
        if (currentPath.StartsWith("/users/"))
            return "تفاصيل المستخدم";

        return currentPath switch
        {
            "/" => "لوحة التحكم",
            "/users" => "إدارة المستخدمين",
            "/subscriptions" => "إدارة الباقات",
            "/listings" => "إدارة العروض",
            "/bookings" => "إدارة الحجوزات",
            "/complaints" => "الدعم والشكاوى",
            "/notifications" => "إرسال الإشعارات",
            "/reports" => "التقارير",
            "/appconfig" => "التحكم والإعدادات",
            "/legal" => "الصفحات القانونية",
            "/audit" => "سجل التدقيق",
            "/settings" => "الإعدادات",
            "/marketing" => "تحليلات التسويق",
            "/versions" => "إدارة الإصدارات",
            "/admin-users" => "إدارة المشرفين",
            "/roles" => "الأدوار والصلاحيات",
            _ => "عشير"
        };
    }
}
