# Alibaba Cloud Deployment Configuration
# Copy this file to deploy-alibaba.env (gitignored) and fill in real values.
# Usage:
#   cp deploy-alibaba.env.example deploy-alibaba.env
#   # edit values
#   source deploy-alibaba.env
#   ./deploy-alibaba.sh deploy

# ===== ECS instance =====
export ECS_HOST="8.213.82.216"                  # Public IP of the ECS instance
export ECS_USER="ecs-user"                       # SSH user (matches existing setup)
export SSH_KEY="$HOME/.ssh/ashare-key.pem"       # Private key path (falls back to password if missing)

# ===== Alibaba Container Registry (ACR) =====
# Public endpoint (used from your dev machine to push)
export ACR_REGISTRY="registry.me-central-1.aliyuncs.com"
# Intranet endpoint (used from ECS to pull — faster, free bandwidth)
export ACR_REGISTRY_INTRANET="registry-vpc.me-central-1.aliyuncs.com"
export ACR_NAMESPACE="ashare"
export ACR_USERNAME="<from-acr-access-credentials>"
export ACR_PASSWORD="<the-docker-login-password-you-set>"

# ===== Image =====
export IMAGE_NAME="ashare-api"
# IMAGE_TAG defaults to current git short-sha (best practice).
# Set this to deploy a specific version, e.g. for rollback:
# export IMAGE_TAG="a3f9c12"

# ===== Container runtime (matches what's running on the server today) =====
export CONTAINER_NAME="ashare-api"
export CONTAINER_PORT="8080"
export HOST_PORT="8080"                          # nginx proxies 443 -> 8080
export REMOTE_ENV_FILE="/home/ecs-user/ashare.env"   # secrets file on server
export REMOTE_SECRETS_DIR="/app/secrets"             # firebase-service-account.json mount
export HEALTH_PATH="/health"                         # endpoint used for post-deploy health check
