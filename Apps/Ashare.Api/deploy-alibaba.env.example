# Ashare API — Deployment Configuration (fast SSH-streaming flow, no registry)
# Copy this file to deploy-alibaba.env (gitignored) and fill in real values.
# Usage:
#   cp deploy-alibaba.env.example deploy-alibaba.env
#   # edit values
#   source deploy-alibaba.env
#   ./deploy-alibaba.sh deploy

# ===== ECS instance =====
export ECS_HOST="8.213.82.216"                  # Public IP
export ECS_USER="ecs-user"                       # SSH user (matches existing prod)
export SSH_KEY="$HOME/.ssh/ashare-key"           # Private key (falls back to password if missing)

# ===== Image =====
export IMAGE_NAME="ashare-api"
# IMAGE_TAG defaults to current git short-sha. Override only for rollback:
# export IMAGE_TAG="a3f9c12"

# ===== Container runtime (matches existing prod) =====
export CONTAINER_NAME="ashare-api"
export CONTAINER_PORT="8080"
export HOST_PORT="8080"                          # nginx proxies 443 -> 8080
export REMOTE_ENV_FILE="/home/ecs-user/ashare.env"
export REMOTE_SECRETS_DIR="/app/secrets"
export HEALTH_PATH="/health"
