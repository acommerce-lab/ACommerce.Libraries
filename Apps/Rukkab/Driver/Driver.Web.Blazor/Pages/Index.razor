@page "/"
@using ACommerce.Templates.Driver.Components
@inject NavigationManager Nav

<div style="max-width:980px;margin:18px auto;font-family:Segoe UI,Helvetica,Arial,sans-serif">
	<header style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
		<h1 style="margin:0">Driver Console</h1>
		<nav>
			<a href="/active" style="margin-right:12px">Active Ride</a>
			<a href="/chats" style="margin-right:12px">Chats</a>
			<a href="/notifications" style="margin-right:12px">Notifications</a>
			<a href="/login">Logout</a>
		</nav>
	</header>

	<div style="display:grid;grid-template-columns:1fr 360px;gap:12px;">
		<div style="background:#fff;border:1px solid #eee;padding:12px;border-radius:8px">
			<div style="height:360px;background:linear-gradient(180deg,#f7f9fc,#eef4ff);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#0b69ff">
				<div style="text-align:center">
					<div style="font-size:32px;font-weight:600">Map stub</div>
					<div style="color:#666;margin-top:6px">(Integrate real map later — this is a demo)</div>
				</div>
			</div>

			<section style="margin-top:12px">
				<h3 style="margin:6px 0">Nearby requests</h3>
				<div style="color:#666">No nearby requests in demo mode — use the Rider UI to request a ride.</div>
			</section>
		</div>

		<aside style="background:#fff;border:1px solid #eee;padding:12px;border-radius:8px">
			<h3 style="margin-top:0">Controls</h3>
			<RideControls BaseUrl="http://127.0.0.1:5002" />
		</aside>
	</div>
</div>
