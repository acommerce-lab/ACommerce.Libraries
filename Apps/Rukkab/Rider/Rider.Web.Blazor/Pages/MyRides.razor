@page "/myrides"
@inject HttpClient Http
@using System.Net.Http.Json

<h2>My Rides</h2>
<style>
  .rides-list { max-width:720px; border:1px solid #eee; padding:12px; border-radius:8px; background:#fff }
  .ride-item { padding:8px; border-bottom:1px solid #f2f2f2 }
  .ride-meta { color:#666; font-size:12px }
</style>

<div class="rides-list">
  @if (Rides == null)
  {
    <div>Loading...</div>
  }
  else if (!Rides.Any())
  {
    <div>No rides yet. Try requesting one from <a href="/">Home</a>.</div>
  }
  else
  {
    @foreach (var r in Rides)
    {
      <div class="ride-item">
        <div><strong>@r.Id</strong> — @r.Status</div>
        <div class="ride-meta">Requested @r.RequestedAt.ToLocalTime().ToString("g") • Pickup: @r.Pickup</div>
      </div>
    }
  }
</div>

@code {
  private List<RideDto>? Rides;

  protected override async Task OnInitializedAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    try
    {
      // Try calling a Rider API endpoint if available
      var res = await Http.GetAsync("http://127.0.0.1:5001/api/rides/mine");
      if (res.IsSuccessStatusCode)
      {
        var items = await res.Content.ReadFromJsonAsync<List<RideDto>>();
        Rides = items ?? new List<RideDto>();
      }
      else
      {
        // fallback sample data
        Rides = Sample();
      }
    }
    catch
    {
      Rides = Sample();
    }
  }

  private List<RideDto> Sample() => new()
  {
    new RideDto { Id = "ride-123", Status = "Requested", Pickup = "Times Square", RequestedAt = DateTime.UtcNow.AddMinutes(-3) },
    new RideDto { Id = "ride-122", Status = "Completed", Pickup = "Union Sq.", RequestedAt = DateTime.UtcNow.AddDays(-1) }
  };

  private class RideDto { public string Id { get; set; } = string.Empty; public string Status { get; set; } = string.Empty; public string Pickup { get; set; } = string.Empty; public DateTime RequestedAt { get; set; } }
}
