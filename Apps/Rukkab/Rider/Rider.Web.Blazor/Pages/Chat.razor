@page "/chats"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client
@using ACommerce.Client.Realtime
@inject HttpClient Http
@inject RealtimeClient? Realtime

<h2>Rukkab — Rider Chat (demo)</h2>
<style>
  .chat-card { max-width:720px; border:1px solid #ddd; padding:12px; border-radius:8px }
  .chat-log { height:240px; overflow:auto; border:1px solid #eee; padding:8px; background:#fafafa }
  .chat-entry { margin:6px 0 }
  .chat-meta { color:#666; font-size:12px }
</style>

<div class="chat-card">
  <div class="chat-log">
    @foreach (var m in Messages)
    {
      <div class="chat-entry">
        <div><strong>@m.Sender</strong> <span class="chat-meta">@m.Time.ToLocalTime().ToString("HH:mm:ss")</span></div>
        <div>@m.Text</div>
      </div>
    }
  </div>

  <div style="margin-top:8px">
    <textarea @bind="Message" rows="3" style="width:100%" placeholder="Type a message"></textarea>
    <div style="margin-top:6px">
      <button @onclick="Send">Send</button>
      <span style="margin-left:12px">Status: @Status</span>
    </div>
  </div>
</div>

@code {
  private string Message { get; set; } = string.Empty;
  private string Status { get; set; } = "idle";
  private HubConnection? _hub;
  private IDisposable? _realtimeHandler;
  private List<(string Sender, string Text, DateTime Time)> Messages { get; set; } = new();

  protected override async Task OnInitializedAsync()
  {
    // Prefer RealtimeClient when available (centralized discovery + options)
    if (Realtime != null)
    {
      try
      {
        // Try a couple of likely service names then fallback to hub URL
        try { await Realtime.ConnectAsync("Rider.Api", "/hubs/chat"); }
        catch { await Realtime.ConnectAsync("Rider", "/hubs/chat"); }

        _realtimeHandler = Realtime.On<string, string>("ReceiveMessage", (sender, text) =>
        {
          Messages.Add((sender ?? "remote", text, DateTime.UtcNow));
          InvokeAsync(StateHasChanged);
        });

        Status = "connected (realtime via wrapper)";
        return;
      }
      catch { /* fall through to direct SignalR/HTTP fallback */ }
    }

    // try direct SignalR connection to Rider API chat hub
    var hubUrl = "http://127.0.0.1:5001/hubs/chat";
    try
    {
      _hub = new HubConnectionBuilder()
        .WithUrl(hubUrl)
        .WithAutomaticReconnect()
        .Build();

      _hub.On<string, string>("ReceiveMessage", (sender, text) =>
      {
        Messages.Add((sender ?? "remote", text, DateTime.UtcNow));
        InvokeAsync(StateHasChanged);
      });

      await _hub.StartAsync();
      Status = "connected (realtime)";
    }
    catch (Exception)
    {
      Status = "realtime unavailable — using local fallback";
    }
  }

  private async Task Send()
  {
    if (string.IsNullOrWhiteSpace(Message)) return;
    var text = Message;
    Message = string.Empty;
    Status = "sending...";

    if (Realtime != null && Realtime.IsConnected)
    {
      try
      {
        await Realtime.SendAsync("SendMessage", new { sender = "rider-1", text = text });
        Messages.Add(("you", text, DateTime.UtcNow));
        Status = "sent (realtime via wrapper)";
      }
      catch (Exception ex)
      {
        Messages.Add(("you (error)", text, DateTime.UtcNow));
        Status = "error: " + ex.Message;
      }
    }
    else
    {
      // fallback to local message / try HTTP post as last resort
      try
      {
        var res = await Http.PostAsJsonAsync("http://127.0.0.1:5001/api/chats/messages", new { text = text });
        if (res.IsSuccessStatusCode)
        {
          Messages.Add(("you (server)", text, DateTime.UtcNow));
          Status = $"sent ({(int)res.StatusCode})";
        }
        else
        {
          Messages.Add(("you (server-error)", text, DateTime.UtcNow));
          Status = $"server {res.StatusCode}";
        }
      }
      catch (Exception)
      {
        Messages.Add(("you (local)", text, DateTime.UtcNow));
        Status = "local (no backend)";
      }
    }
  }

  public async ValueTask DisposeAsync()
  {
    if (_realtimeHandler != null)
    {
      _realtimeHandler.Dispose();
    }

    if (_hub != null)
    {
      await _hub.DisposeAsync();
    }
  }
}
